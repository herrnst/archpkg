# Maintainer: Hector Martin <marcan@marcan.st>

pkgname=uboot-asahi
_ver=2026.04
_commitdate=20260501
_commitid=10c5e0e5f01bf7360ecb8dc06e02daba4c6b60e4

pkgver=${_ver}+git${_commitdate}.${_commitid:0:7}
pkgrel=1
pkgdesc='U-Boot for Apple Silicon Macs'
_srcname=u-boot-${_commitid}
arch=('aarch64')
url='http://asahilinux.org'
license=('MIT' 'GPL2')
makedepends=( bc imagemagick )
source=(
  "u-boot-${pkgver}.tar.gz::https://github.com/AsahiLinux/u-boot/archive/${_commitid}.tar.gz"
)
sha256sums=('3c7693aba50ef3041a08b03dda180c47b15bf28c6ab927049d74eae0c3287302')
b2sums=('593a449c42dae75fda87b2a53a7c17a10f8ac85d59775ab40a8a1cff600ab2dfd2369cbaf8d0dcf7434b506edd9539b7e2e8568847fdeabbb61914dd720d7992')

prepare() {
  cd "${srcdir}/$_srcname"
  make apple_m1_defconfig
}

build() {
  cd "${srcdir}/$_srcname"
  make
}

package() {
  cd "${srcdir}"

  tgtdir="$pkgdir/usr/lib/asahi-boot"

  install -Dt "$tgtdir" -m644 "$_srcname/u-boot-nodtb.bin"
  install -Dt "$tgtdir/dtb" -m644 "$_srcname/dts/upstream/src/arm64/apple/"t[86]*.dtb
}
